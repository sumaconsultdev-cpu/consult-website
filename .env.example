# ============================================================================
# Suma Consultation — environment variables
# Copy to .env.local for local dev. Never commit real secrets.
# Every secret below is required in production. The app will refuse to boot if
# any required var is missing.
# ============================================================================

# --- Application -----------------------------------------------------------
APP_BASE_URL=http://localhost:3000
NODE_ENV=development
APP_TIMEZONE=Asia/Kolkata
# 32+ char random string used as the master server secret (signing, derived keys)
APP_SECRET=

# --- Supabase --------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
# Anon key is unused by this app's client code (all reads go through server
# routes that use the service role). Kept here in case future client features
# need it and to satisfy supabase-js when instantiated client-side.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Grants full DB access. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# --- Rate limiting (Upstash Redis) -----------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Razorpay (test mode for now) ------------------------------------------
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
# When unset, the app uses a built-in mock driver (orders + signatures faked).
PAYMENT_DRIVER=mock  # mock | razorpay

# --- WhatsApp (Meta Cloud API) ---------------------------------------------
WHATSAPP_DRIVER=mock  # mock | meta
META_WA_PHONE_NUMBER_ID=
META_WA_ACCESS_TOKEN=
META_WA_TEMPLATE_CONFIRMATION=booking_confirmation
# Admin's WhatsApp number that also receives every booking notification.
ADMIN_WHATSAPP_NUMBER=

# --- Email fallback (Resend) -----------------------------------------------
EMAIL_DRIVER=mock  # mock | resend
RESEND_API_KEY=
EMAIL_FROM="Suma Consultation <noreply@example.com>"
ADMIN_EMAIL=

# --- Admin bootstrap -------------------------------------------------------
# Random secret used to authorize the one-time /admin/setup. Rotate or unset
# after the admin password has been created.
ADMIN_SETUP_TOKEN=

# --- Cron (Vercel Cron uses this to authorize the release-expired job) -----
CRON_SECRET=
